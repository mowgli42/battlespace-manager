FROM node:22-alpine AS build
WORKDIR /app
COPY services/entity-display/web/package.json services/entity-display/web/package-lock.json* ./
RUN npm install
COPY services/entity-display/web/ .
ARG VITE_API_URL=
ENV VITE_API_URL=${VITE_API_URL}
RUN npm run build

FROM nginx:alpine
COPY services/entity-display/web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 8080
